# Cutagent infrastructure configuration.
#
# Variables below either map to the typed Settings object in packages/core/config
# (see build_settings()) or are narrow runtime switches documented near their
# direct consumers. Values shown are the BUILT-IN DEFAULTS — uncomment and
# override only what you need. Provider API keys are deliberately NOT here: they
# live in the SecretStore / ProviderProfile, never in env/Settings.

# ── Storage backend (settings.storage.*) ───────────────────────────────────
# Persistence backend: sqlalchemy | postgres | memory (memory is tests/demo only).
CUTAGENT_STORAGE_BACKEND=sqlalchemy
# Database URL. Required (no default) when the SQLAlchemy backend is active.
CUTAGENT_DATABASE_URL=postgresql+psycopg://cutagent:cutagent@127.0.0.1:55432/cutagent
# SQLAlchemy engine pool tuning for non-sqlite backends.
CUTAGENT_DB_POOL_SIZE=5
CUTAGENT_DB_MAX_OVERFLOW=10
CUTAGENT_DB_POOL_RECYCLE=1800
CUTAGENT_DB_POOL_TIMEOUT=30

# ── Durable object store (settings.object_store.*) ─────────────────────────
# Tiered store toggle: "1" = tiered (durable + ephemeral), "0" = durable only.
CUTAGENT_OBJECTSTORE_TIERED=1
# Durable backend: local | s3
CUTAGENT_OBJECTSTORE_BACKEND=local
# Durable bucket name (used by both local and s3 backends).
CUTAGENT_OBJECTSTORE_BUCKET=cutagent-local
# Optional: dedicated bucket for 'material' purposes (shared source-asset library:
# portrait/broll/video/voice_reference/bgm/font/cover_template). Empty = materials
# write to the durable bucket above (prior single-bucket behaviour).
# CUTAGENT_OBJECTSTORE_MATERIALS_BUCKET=
# Optional: extra read-only buckets the durable store may READ (comma-separated),
# e.g. a shared materials bucket or another env's output bucket. Writes never go here.
# CUTAGENT_OBJECTSTORE_READ_BUCKETS=
# Filesystem root for the local durable backend.
CUTAGENT_LOCAL_OBJECTSTORE_PATH=.data/objectstore

# ── Durable S3/MinIO transport (settings.object_store.s3.*) ────────────────
# Only used when CUTAGENT_OBJECTSTORE_BACKEND=s3. Access/secret keys here are
# MinIO/OSS connection params (infra), not provider API secrets.
CUTAGENT_OBJECTSTORE_ENDPOINT=http://127.0.0.1:9000
CUTAGENT_OBJECTSTORE_ACCESS_KEY=
CUTAGENT_OBJECTSTORE_SECRET_KEY=
CUTAGENT_OBJECTSTORE_REGION=us-east-1
CUTAGENT_OBJECTSTORE_ADDRESSING_STYLE=path
CUTAGENT_OBJECTSTORE_MULTIPART_THRESHOLD_MB=8
CUTAGENT_OBJECTSTORE_MULTIPART_CHUNK_MB=8
CUTAGENT_OBJECTSTORE_MAX_CONCURRENCY=4
CUTAGENT_OBJECTSTORE_CONNECT_TIMEOUT=10
CUTAGENT_OBJECTSTORE_READ_TIMEOUT=120
CUTAGENT_OBJECTSTORE_MAX_ATTEMPTS=5
# OSS 下载缓存治理（0=禁用）：本地缓存上限字节数 / 缓存 TTL 小时数
# CUTAGENT_OBJECTSTORE_CACHE_MAX_BYTES=0
# CUTAGENT_OBJECTSTORE_CACHE_TTL_HOURS=0

# ── Ephemeral object store (settings.object_store.ephemeral.*) ─────────────
# Scratch tier used when CUTAGENT_OBJECTSTORE_TIERED=1.
CUTAGENT_EPHEMERAL_OBJECTSTORE_BACKEND=local
CUTAGENT_EPHEMERAL_OBJECTSTORE_BUCKET=cutagent-ephemeral
# Local ephemeral root. Default: <system temp dir>/cutagent-ephemeral
# CUTAGENT_OBJECTSTORE_EPHEMERAL_PATH=/tmp/cutagent-ephemeral
# Ephemeral s3 connection params (only used when backend=s3).
CUTAGENT_EPHEMERAL_OBJECTSTORE_ENDPOINT=http://127.0.0.1:9000
CUTAGENT_EPHEMERAL_OBJECTSTORE_ACCESS_KEY=
CUTAGENT_EPHEMERAL_OBJECTSTORE_SECRET_KEY=
CUTAGENT_EPHEMERAL_OBJECTSTORE_REGION=us-east-1
CUTAGENT_EPHEMERAL_OBJECTSTORE_ADDRESSING_STYLE=path

# ── Workflow runtime + Temporal (settings.workflow.*) ──────────────────────
# Runtime: local | temporal
CUTAGENT_WORKFLOW_RUNTIME=local
CUTAGENT_TEMPORAL_ADDRESS=127.0.0.1:7233
CUTAGENT_TEMPORAL_NAMESPACE=default
CUTAGENT_TEMPORAL_TASK_QUEUE=cutagent-production

# ── Auth / registration policy (settings.auth.*) ───────────────────────────
# Open public self-service registration: true | false
CUTAGENT_REGISTRATION_OPEN=true
# Salt mixed into registration-code hashes (override in production).
CUTAGENT_REGISTRATION_CODE_SALT=local-dev-registration-code-salt
# Seed local bootstrap users/codes. Disable in production after real admins exist.
CUTAGENT_SEED_LOCAL_AUTH=true
# Brute-force limiter windows.
CUTAGENT_AUTH_MAX_LOGIN_ATTEMPTS=8
CUTAGENT_AUTH_LOGIN_WINDOW_MINUTES=15
CUTAGENT_AUTH_MAX_REGISTRATION_ATTEMPTS=5
CUTAGENT_AUTH_REGISTRATION_WINDOW_MINUTES=60
# Trust X-Forwarded-For only behind a trusted proxy/LB that overwrites it.
CUTAGENT_AUTH_TRUST_FORWARDED_FOR=false
# Blank = derive cookie Secure flag from request scheme / trusted forwarded proto.
CUTAGENT_AUTH_COOKIE_SECURE=

# ── Secret store location (settings.secret_store.*) ────────────────────────
# On-disk directory for the local dev secret envelope store (NOT the secrets
# themselves — those are owned by SecretStore).
CUTAGENT_SECRET_STORE_DIR=.data/secrets

# ── Media tooling (settings.media.*) ───────────────────────────────────────
# Explicit ffmpeg/ffprobe binary paths. Unset = resolve via PATH, then
# ~/.local/bin, then the bare command name.
# CUTAGENT_FFMPEG_BIN=
# CUTAGENT_FFPROBE_BIN=

# ── API process behaviour (settings.api.*) ─────────────────────────────────
# Disable the in-process outbox dispatcher background task: "1" disables it.
CUTAGENT_DISABLE_BACKGROUND_DISPATCHER=0

# ── Provider gateway policy (settings.providers.*) ─────────────────────────
# Extra outbound API hosts appended to the built-in provider SSRF allow-list.
CUTAGENT_ALLOWED_API_HOSTS=
# Defense-in-depth provider-profile host re-check before secret delivery.
CUTAGENT_ENFORCE_PROVIDER_HOST_ALLOWLIST=0
# Provider call fallback is OFF by default: no real profile => explicit error.
CUTAGENT_ALLOW_SANDBOX_FALLBACK=0

# ── Publishing adapter (direct runtime switch) ─────────────────────────────
# Production default is 小V猫 CDP; use sandbox.publish only for tests/dry runs.
CUTAGENT_PUBLISH_ADAPTER=xiaovmao.cdp
CUTAGENT_XIAOVMAO_CDP_HOST=127.0.0.1
CUTAGENT_XIAOVMAO_CDP_PORT=9222

# ── Upload ingestion (settings.upload.*) ───────────────────────────────────
# Browser-direct upload to OSS via presigned PUT (hard 100 MiB per-file cap lives in the contract).
# Lifetime of a presigned PUT URL handed to the browser:
CUTAGENT_UPLOAD_PRESIGN_TTL_SECONDS=900
# Comma-separated web origins allowed to PUT directly to the durable upload bucket
# (provisioned onto the OSS bucket CORS rules by scripts/provision_oss_cors.py).
CUTAGENT_UPLOAD_CORS_ALLOWED_ORIGINS=https://app.shuying.cyou,http://localhost:5173
CUTAGENT_UPLOAD_NORMALIZE_VIDEO=0

# ── Provider balance polling (settings.balance.*) ──────────────────────────
# Periodic poller is opt-in; manual refresh endpoints still work when disabled.
CUTAGENT_BALANCE_POLLER_ENABLED=0
CUTAGENT_BALANCE_POLL_INTERVAL_SECONDS=900
CUTAGENT_BALANCE_REQUEST_TIMEOUT_SECONDS=10

# ── Case learning loop (settings.learning.*) ───────────────────────────────
CUTAGENT_LEARNING_RETRO_WINDOW_DAYS=3
CUTAGENT_LEARNING_REWARD_DRAFT_ADOPTED=0.2
CUTAGENT_LEARNING_REWARD_DRAFT_PICK=-0.05
CUTAGENT_LEARNING_REWARD_VIDEO_PRODUCED=0.4
CUTAGENT_LEARNING_REWARD_PUBLISHED=0.7
CUTAGENT_LEARNING_REWARD_VIDEO_DISCARDED_SCRIPT=-0.3
CUTAGENT_LEARNING_REWARD_STALE_UNPUBLISHED=-0.1
CUTAGENT_LEARNING_BUMP_MIN_SAMPLES=5
CUTAGENT_LEARNING_BUMP_MISS_STREAK=3
CUTAGENT_LEARNING_BUMP_CONSISTENCY_FLOOR=0.6

# ── Motion guard sensor (settings.motion_guard.*) ──────────────────────────
CUTAGENT_MOTION_GUARD_SAMPLE_FPS=10.0
CUTAGENT_MOTION_GUARD_WIDTH=360
CUTAGENT_MOTION_GUARD_WINDOW_SEC=1.5
CUTAGENT_MOTION_GUARD_HOP_SEC=0.75
CUTAGENT_MOTION_GUARD_ACTIVE_PX=1.5
CUTAGENT_MOTION_GUARD_HARD_PX=3.0
CUTAGENT_MOTION_GUARD_P95_HARD_PX=7.0
CUTAGENT_MOTION_GUARD_TAIL_Y_RANGE_HARD_PX=70.0
CUTAGENT_MOTION_GUARD_TAIL_NET_Y_HARD_PX=65.0
CUTAGENT_MOTION_GUARD_SMOOTH_MOVE_STRAIGHTNESS=0.88
CUTAGENT_MOTION_GUARD_SMOOTH_MOVE_FLIP_RATIO=0.16
CUTAGENT_MOTION_GUARD_SWEEP_AXIS_RATIO=2.3
CUTAGENT_MOTION_GUARD_JITTER_FLIP_RATIO=0.22
CUTAGENT_MOTION_GUARD_JITTER_JERK_RATIO=0.65
CUTAGENT_MOTION_GUARD_REFINE_MIN_DURATION=0.8
CUTAGENT_MOTION_GUARD_REFINE_ROUND_SEC=0.1

# ── Arch-hardening opt-in switches ─────────────────────────────────────────
# All OFF / safe-default below: unset = the prior in-process behaviour, never
# fail-open. Enable per deployment topology / policy.
#
# Cross-process coordination. Set to a redis:// URL to share provider rate
# limits, the live event-stream fanout and stream tokens across API/worker
# replicas. Unset = per-process limiting (correct for single-replica). On Redis
# outage the limiter fails SAFE back to per-process, it does not fail-open.
# CUTAGENT_REDIS_URL=
# Require Redis (#81): when true, /api/health/ready reports not-ready (503) if any
# Redis-backed singleton (event hub / stream tokens / provider limiter) is degraded,
# so the orchestrator drains the replica instead of serving with cross-replica
# guarantees silently broken. Default false = degrade-in-place (fail-safe).
# CUTAGENT_REDIS_REQUIRED=
# Per-hop budget (seconds) for the public /api/health/network segment probes (#77).
# The OSS / Temporal hops are live round-trips run on a worker thread and abandoned
# past this budget, so a slow dependency can't make this unauthenticated endpoint a
# DoS amplifier. Default 2.0.
# CUTAGENT_HEALTH_PROBE_TIMEOUT=
# Per-provider concurrency / QPS caps (apply in-process and, with Redis, cluster-wide).
# CUTAGENT_PROVIDER_MAX_INFLIGHT=
# CUTAGENT_PROVIDER_MAX_QPS=
#
# Provider circuit breaker: "1" fails fast on a profile whose recent error rate
# exceeds the threshold (deterministic; does NOT re-route selection). Default OFF.
# CUTAGENT_PROVIDER_CIRCUIT_BREAKER=
# CUTAGENT_PROVIDER_CIRCUIT_ERROR_RATE=0.5
# CUTAGENT_PROVIDER_CIRCUIT_WINDOW=24
#
# Per-worker ffmpeg render concurrency. Unset = 2.
# CUTAGENT_RENDER_MAX_INFLIGHT=
#
# Retain a cancelled run's ephemeral intermediates for debugging ("1"), reclaimed
# by the time-based sweep after N hours. (Failed / worker-lost runs always retain
# for resume regardless.) Default OFF.
# CUTAGENT_KEEP_FAILED_EPHEMERAL=
# CUTAGENT_EPHEMERAL_FAILED_RETENTION_HOURS=
