{
  "name": "cutagent-cleanslate-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "generate:api": "openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "export:openapi": "cd ../.. && uv run --extra dev python scripts/export_openapi.py"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  },
  "knip": {
    "ignoreBinaries": [
      "uv"
    ]
  }
}
